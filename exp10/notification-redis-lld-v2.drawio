          <mxGeometry height="90" width="200" x="-565" y="952" as="geometry" />
        </mxCell>
        <mxCell id="cls-pw" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#003333;fillColor=#005555;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;PushWorker&lt;/b&gt; extends BaseWorker&lt;hr style=&apos;border-color:#44dddd;&apos;/&gt;- fcmClient: FCM&lt;br&gt;+ deliver(n): void&lt;br&gt;  // FCM.send / APNs.send" vertex="1">
          <mxGeometry height="90" width="200" x="-340" y="952" as="geometry" />
        </mxCell>
        <mxCell id="cls-persistw" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#003333;fillColor=#005555;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;PersistWorker&lt;/b&gt; extends BaseWorker&lt;hr style=&apos;border-color:#44dddd;&apos;/&gt;- cassandraClient: Cassandra&lt;br&gt;- redisCache: RedisCache&lt;br&gt;+ deliver(n): void // write DB + cache" vertex="1">
          <mxGeometry height="90" width="220" x="-115" y="952" as="geometry" />
        </mxCell>

