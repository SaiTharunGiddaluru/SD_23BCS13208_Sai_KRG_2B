        <!-- ═══════════════════════════════════════════════
             H. fanOut pseudo-code
        ═══════════════════════════════════════════════ -->
        <mxCell id="h-hdr" parent="1" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="H. NotificationService.fanOut() — Pseudo-code" vertex="1">
          <mxGeometry height="24" width="400" x="-800" y="1648" as="geometry" />
        </mxCell>

        <mxCell id="pseudo-fanout" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#333333;fillColor=#1a1a1a;fontColor=#e8e8e8;fontFamily=Courier New;fontSize=11;rounded=0;" value="async fanOut(notification: Notification) {&lt;br&gt;&lt;br&gt;  // 1. Render template&lt;br&gt;  const body = templateEngine.render(&lt;br&gt;    notification.type, notification.channel,&lt;br&gt;    notification.payload, notification.locale&lt;br&gt;  );&lt;br&gt;&lt;br&gt;  // 2. Check preference&lt;br&gt;  const pref = await prefRepo.find(userId, channel);&lt;br&gt;  if (!pref.enabled) return;  // skip channel&lt;br&gt;&lt;br&gt;  // 3. Rate limit check&lt;br&gt;  const key = `rate:${userId}:${channel}`;&lt;br&gt;  const count = await redis.incr(key);&lt;br&gt;  if (count === 1) await redis.expire(key, 60);&lt;br&gt;  if (count &gt; RATE_LIMIT) return;  // throttle&lt;br&gt;&lt;br&gt;  // 4. Publish to Redis Pub/Sub (in-app, real-time)&lt;br&gt;  if (channel === 'in_app') {&lt;br&gt;    await redisPublisher.publish(userId, {&lt;br&gt;      ...notification, body, unread_count&lt;br&gt;    });&lt;br&gt;  }&lt;br&gt;&lt;br&gt;  // 5. Enqueue to Kafka (durable, all channels)&lt;br&gt;  await kafkaProducer.send({&lt;br&gt;    topic: 'notification.events',&lt;br&gt;    messages: [{ key: userId,&lt;br&gt;      value: JSON.stringify({ ...notification, body })&lt;br&gt;    }]&lt;br&gt;  });&lt;br&gt;}" vertex="1">
          <mxGeometry height="380" width="400" x="-800" y="1678" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             I. PersistWorker pseudo-code
        ═══════════════════════════════════════════════ -->
        <mxCell id="i-hdr" parent="1" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="I. PersistWorker.deliver() — Pseudo-code" vertex="1">
          <mxGeometry height="24" width="360" x="-360" y="1648" as="geometry" />
        </mxCell>

        <mxCell id="pseudo-persist" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#333333;fillColor=#1a1a1a;fontColor=#e8e8e8;fontFamily=Courier New;fontSize=11;rounded=0;" value="async deliver(n: Notification) {&lt;br&gt;&lt;br&gt;  // 1. Idempotency guard&lt;br&gt;  const idemKey = `idem:${n.idempotency_key}`;&lt;br&gt;  const already = await redis.set(&lt;br&gt;    idemKey, '1', 'NX', 'EX', 86400&lt;br&gt;  );&lt;br&gt;  if (!already) return;  // duplicate, skip&lt;br&gt;&lt;br&gt;  // 2. Write to Cassandra&lt;br&gt;  await cassandra.execute(`&lt;br&gt;    INSERT INTO notifications (...) VALUES (?)&lt;br&gt;  `, [n.notification_id, n.user_id, ...]);&lt;br&gt;&lt;br&gt;  // 3. Increment unread counter&lt;br&gt;  await redis.incr(`unread:${n.user_id}`);&lt;br&gt;  await redis.expire(`unread:${n.user_id}`, 604800);&lt;br&gt;&lt;br&gt;  // 4. Add to sorted set (hot read path)&lt;br&gt;  const score = Date.now();&lt;br&gt;  await redis.zadd(&lt;br&gt;    `notifs:${n.user_id}`, score, JSON.stringify(n)&lt;br&gt;  );&lt;br&gt;  // Keep only latest 100 entries&lt;br&gt;  await redis.zremrangebyrank(&lt;br&gt;    `notifs:${n.user_id}`, 0, -101&lt;br&gt;  );&lt;br&gt;  await redis.expire(`notifs:${n.user_id}`, 86400);&lt;br&gt;}" vertex="1">
          <mxGeometry height="340" width="390" x="-360" y="1678" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             J. READ PATH SEQUENCE
        ═══════════════════════════════════════════════ -->
        <mxCell id="j-hdr" parent="1" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="J. Read Path — GET /notifications (two-tier cache)" vertex="1">
          <mxGeometry height="24" width="380" x="100" y="1648" as="geometry" />
        </mxCell>

        <mxCell id="read-client" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1e6b1e;fontColor=#ffffff;strokeColor=#1a4a1a;fontStyle=1;" value="Client" vertex="1"><mxGeometry height="36" width="80" x="100" y="1678" as="geometry"/></mxCell>
        <mxCell id="read-gw" parent="1" style="whiteSpace=wrap;html=1;fillColor=#003070;fontColor=#ffffff;strokeColor=#001a40;fontStyle=1;" value="API Gateway" vertex="1"><mxGeometry height="36" width="110" x="222" y="1678" as="geometry"/></mxCell>
        <mxCell id="read-redis" parent="1" style="whiteSpace=wrap;html=1;fillColor=#a30000;fontColor=#ffffff;strokeColor=#6b0000;fontStyle=1;" value="Redis Cache" vertex="1"><mxGeometry height="36" width="110" x="378" y="1678" as="geometry"/></mxCell>
        <mxCell id="read-cass" parent="1" style="whiteSpace=wrap;html=1;fillColor=#003070;fontColor=#ffffff;strokeColor=#001a40;fontStyle=1;" value="Cassandra" vertex="1"><mxGeometry height="36" width="110" x="537" y="1678" as="geometry"/></mxCell>

        <mxCell id="rll1" parent="1" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="140" y="1714" as="sourcePoint"/><mxPoint x="140" y="1990" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="rll2" parent="1" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="277" y="1714" as="sourcePoint"/><mxPoint x="277" y="1990" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="rll3" parent="1" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="433" y="1714" as="sourcePoint"/><mxPoint x="433" y="1990" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="rll4" parent="1" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="592" y="1714" as="sourcePoint"/><mxPoint x="592" y="1990" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="ra1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="140" y="1740" as="sourcePoint"/><mxPoint x="275" y="1740" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ra1l" parent="1" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=11;" value="1. GET /notifications?user_id=" vertex="1"><mxGeometry height="16" width="180" x="128" y="1722" as="geometry"/></mxCell>

        <mxCell id="ra2" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#a30000;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="277" y="1768" as="sourcePoint"/><mxPoint x="431" y="1768" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ra2l" parent="1" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontStyle=1;fontSize=11;" value="2. ZREVRANGE notifs:{id} 0 19" vertex="1"><mxGeometry height="16" width="190" x="254" y="1750" as="geometry"/></mxCell>

        <mxCell id="ra3-hit" parent="1" style="endArrow=block;endFill=1;html=1;dashed=1;strokeColor=#1e6b1e;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="431" y="1798" as="sourcePoint"/><mxPoint x="279" y="1798" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ra3-hitl" parent="1" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontStyle=1;fontSize=11;" value="3a. HIT — return 20 notifs" vertex="1"><mxGeometry height="16" width="170" x="310" y="1780" as="geometry"/></mxCell>

        <mxCell id="ra3-miss" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="433" y="1838" as="sourcePoint"/><mxPoint x="590" y="1838" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ra3-missl" parent="1" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=11;" value="3b. MISS — SELECT * WHERE user_id" vertex="1"><mxGeometry height="16" width="205" x="393" y="1820" as="geometry"/></mxCell>

        <mxCell id="ra4" parent="1" style="endArrow=block;endFill=1;html=1;dashed=1;strokeColor=#333333;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="590" y="1868" as="sourcePoint"/><mxPoint x="433" y="1868" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ra4l" parent="1" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=11;" value="4. rows — warm cache (ZADD)" vertex="1"><mxGeometry height="16" width="178" x="430" y="1850" as="geometry"/></mxCell>

        <mxCell id="ra5" parent="1" style="endArrow=block;endFill=1;html=1;dashed=1;strokeColor=#333333;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="277" y="1908" as="sourcePoint"/><mxPoint x="140" y="1908" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ra5l" parent="1" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontStyle=1;fontSize=11;" value="5. 200 OK  [ notifications + unread_count ]" vertex="1"><mxGeometry height="16" width="240" x="100" y="1890" as="geometry"/></mxCell>

        <!-- ═══════════════════════════════════════════════
             K. ERROR HANDLING
        ═══════════════════════════════════════════════ -->
        <mxCell id="k-hdr" parent="1" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="K. Error Handling &amp; Edge Cases" vertex="1">
          <mxGeometry height="24" width="320" x="760" y="1648" as="geometry" />
        </mxCell>

        <!-- header row -->
        <mxCell id="err-head" parent="1" style="whiteSpace=wrap;html=1;fillColor=#333333;fontColor=#ffffff;strokeColor=#000000;fontStyle=1;align=left;" value="  Scenario                                 |  Handling" vertex="1">
          <mxGeometry height="30" width="640" x="760" y="1678" as="geometry" />
        </mxCell>

        <mxCell id="err-r1" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ccccff;strokeColor=#333366;align=left;" value="  User offline (no WS)                    |  Redis PUBLISH drops silently. Kafka worker delivers async." vertex="1"><mxGeometry height="28" width="640" x="760" y="1708" as="geometry"/></mxCell>
        <mxCell id="err-r2" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#cccccc;strokeColor=#333333;align=left;" value="  Duplicate publish request               |  idempotency_key SET NX in Redis — skip if key exists." vertex="1"><mxGeometry height="28" width="640" x="760" y="1736" as="geometry"/></mxCell>
        <mxCell id="err-r3" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ccccff;strokeColor=#333366;align=left;" value="  Email/SMS provider down                 |  Circuit breaker opens after 5% error rate; pause consumer." vertex="1"><mxGeometry height="28" width="640" x="760" y="1764" as="geometry"/></mxCell>
        <mxCell id="err-r4" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#cccccc;strokeColor=#333333;align=left;" value="  Kafka consumer lag spike                |  Scale workers horizontally; alert if lag &gt; 10k messages." vertex="1"><mxGeometry height="28" width="640" x="760" y="1792" as="geometry"/></mxCell>
        <mxCell id="err-r5" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ccccff;strokeColor=#333366;align=left;" value="  Redis unavailable                       |  WS delivery fails gracefully; Kafka path unaffected." vertex="1"><mxGeometry height="28" width="640" x="760" y="1820" as="geometry"/></mxCell>
        <mxCell id="err-r6" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#cccccc;strokeColor=#333333;align=left;" value="  Cassandra write fails                   |  Worker nacks; Kafka retries up to 3x then sends to DLQ." vertex="1"><mxGeometry height="28" width="640" x="760" y="1848" as="geometry"/></mxCell>
        <mxCell id="err-r7" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ccccff;strokeColor=#333366;align=left;" value="  User disables preference mid-send       |  Worker re-checks pref at delivery time, not only at publish." vertex="1"><mxGeometry height="28" width="640" x="760" y="1876" as="geometry"/></mxCell>
        <mxCell id="err-r8" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#cccccc;strokeColor=#333333;align=left;" value="  Quiet hours edge (midnight boundary)    |  Re-queue with delivery_after timestamp; SQS delay queue." vertex="1"><mxGeometry height="28" width="640" x="760" y="1904" as="geometry"/></mxCell>
        <mxCell id="err-r9" parent="1" style="whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ccccff;strokeColor=#333366;align=left;" value="  Notification flood (promo blast)        |  Per-user Redis rate limiter + batch-publish with back-off." vertex="1"><mxGeometry height="28" width="640" x="760" y="1932" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
