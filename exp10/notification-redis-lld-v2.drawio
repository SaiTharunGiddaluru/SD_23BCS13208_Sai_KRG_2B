        <!-- NotificationService — dark amber bg, white text -->
        <mxCell id="cls-ns" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#5a3e00;fillColor=#8a5c00;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;&lt;&lt;Service&gt;&gt; NotificationService&lt;/b&gt;&lt;hr style=&apos;border-color:#ffcc44;&apos;/&gt;&lt;i&gt;- redisClient: RedisClient&lt;br&gt;- kafkaProducer: KafkaProducer&lt;br&gt;- prefRepo: UserPreferenceRepository&lt;br&gt;- templateEngine: TemplateEngine&lt;/i&gt;&lt;hr style=&apos;border-color:#ffcc44;&apos;/&gt;+ publish(req: PublishRequest): void&lt;br&gt;+ validateAndEnrich(req): Notification&lt;br&gt;+ fanOut(n: Notification): void&lt;br&gt;+ checkPreference(userId, channel): boolean&lt;br&gt;+ buildPayload(template, data): string" vertex="1">
          <mxGeometry height="175" width="290" x="-800" y="118" as="geometry" />
        </mxCell>

        <!-- RedisPublisher — dark red -->
        <mxCell id="cls-rp" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#6b0000;fillColor=#a30000;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;&lt;&lt;Component&gt;&gt; RedisPublisher&lt;/b&gt;&lt;hr style=&apos;border-color:#ff9999;&apos;/&gt;&lt;i&gt;- client: ioredis.Redis&lt;br&gt;- channelPrefix: string = &quot;notif:user:&quot;&lt;/i&gt;&lt;hr style=&apos;border-color:#ff9999;&apos;/&gt;+ publish(userId: string, payload: string): void&lt;br&gt;+ getChannel(userId): string&lt;br&gt;+ pingHealth(): boolean" vertex="1">
          <mxGeometry height="130" width="270" x="-800" y="308" as="geometry" />
        </mxCell>

        <!-- WebSocketManager — dark green -->
        <mxCell id="cls-ws" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#1a4a1a;fillColor=#1e6b1e;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;&lt;&lt;Component&gt;&gt; WebSocketManager&lt;/b&gt;&lt;hr style=&apos;border-color:#88ff88;&apos;/&gt;&lt;i&gt;- redisSubscriber: RedisSubscriber&lt;br&gt;- socketMap: Map&amp;lt;userId, Socket&amp;gt;&lt;br&gt;- heartbeatInterval: number&lt;/i&gt;&lt;hr style=&apos;border-color:#88ff88;&apos;/&gt;+ onConnect(socket: Socket): void&lt;br&gt;+ onDisconnect(userId: string): void&lt;br&gt;+ subscribeChannel(userId): void&lt;br&gt;+ unsubscribeChannel(userId): void&lt;br&gt;+ sendToUser(userId, payload): void&lt;br&gt;+ handleHeartbeat(socket): void" vertex="1">
          <mxGeometry height="168" width="280" x="-800" y="453" as="geometry" />
        </mxCell>

        <!-- KafkaProducer — dark purple -->
        <mxCell id="cls-kp" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#2e0050;fillColor=#4a007a;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;&lt;&lt;Component&gt;&gt; KafkaProducer&lt;/b&gt;&lt;hr style=&apos;border-color:#cc88ff;&apos;/&gt;&lt;i&gt;- producer: Kafka.Producer&lt;br&gt;- topic: string = &quot;notification.events&quot;&lt;/i&gt;&lt;hr style=&apos;border-color:#cc88ff;&apos;/&gt;+ send(event: NotificationEvent): void&lt;br&gt;+ sendBatch(events: NotificationEvent[]): void&lt;br&gt;+ flush(): Promise&amp;lt;void&amp;gt;" vertex="1">
          <mxGeometry height="130" width="260" x="-800" y="636" as="geometry" />
        </mxCell>

        <!-- BaseWorker — dark navy -->
        <mxCell id="cls-bw" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#001a40;fillColor=#003070;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;&lt;&lt;abstract&gt;&gt; BaseWorker&lt;/b&gt;&lt;hr style=&apos;border-color:#88bbff;&apos;/&gt;&lt;i&gt;- consumer: KafkaConsumer&lt;br&gt;- dlqProducer: KafkaProducer&lt;br&gt;- maxRetries: int = 3&lt;/i&gt;&lt;hr style=&apos;border-color:#88bbff;&apos;/&gt;# abstract deliver(n: Notification): void&lt;br&gt;+ consume(): void  // main loop&lt;br&gt;+ handleError(e, n): void  // retry / DLQ&lt;br&gt;+ checkIdempotency(key): boolean&lt;br&gt;+ ack(): void" vertex="1">
          <mxGeometry height="155" width="270" x="-800" y="782" as="geometry" />
        </mxCell>

        <!-- Concrete workers — dark teal -->
        <mxCell id="cls-ew" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#003333;fillColor=#005555;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;EmailWorker&lt;/b&gt; extends BaseWorker&lt;hr style=&apos;border-color:#44dddd;&apos;/&gt;- sesClient: AWS.SES&lt;br&gt;+ deliver(n): void&lt;br&gt;  // template &gt; SES.sendEmail" vertex="1">
          <mxGeometry height="90" width="200" x="-800" y="952" as="geometry" />
