        <mxCell id="model-pr" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#5a3e00;fillColor=#8a5c00;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;PublishRequest  (REST body)&lt;/b&gt;&lt;hr style=&apos;border-color:#ffcc44;&apos;/&gt;{&lt;br&gt;  user_id:         UUID&lt;br&gt;  type:            string   // e.g. order_update&lt;br&gt;  payload:         object   // template variables&lt;br&gt;  channels:        string[] // [&quot;in_app&quot;,&quot;email&quot;]&lt;br&gt;  idempotency_key: string   // client-supplied&lt;br&gt;  priority:        &quot;high&quot; | &quot;normal&quot;&lt;br&gt;}" vertex="1">
          <mxGeometry height="158" width="300" x="940" y="118" as="geometry" />
        </mxCell>

        <mxCell id="model-notif" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#001a40;fillColor=#003070;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;Notification  (internal / Kafka event)&lt;/b&gt;&lt;hr style=&apos;border-color:#88bbff;&apos;/&gt;{&lt;br&gt;  notification_id:  UUID&lt;br&gt;  user_id:          UUID&lt;br&gt;  type:             string&lt;br&gt;  channel:          string&lt;br&gt;  rendered_body:    string  // post-template&lt;br&gt;  subject:          string  // email only&lt;br&gt;  status:           string&lt;br&gt;  idempotency_key:  string&lt;br&gt;  created_at:       ISO8601&lt;br&gt;  priority:         string&lt;br&gt;}" vertex="1">
          <mxGeometry height="198" width="300" x="940" y="292" as="geometry" />
        </mxCell>

        <mxCell id="model-ws" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#1a4a1a;fillColor=#1e6b1e;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;WebSocket Push Payload&lt;/b&gt;&lt;hr style=&apos;border-color:#88ff88;&apos;/&gt;{&lt;br&gt;  event:           &quot;notification&quot;&lt;br&gt;  notification_id: UUID&lt;br&gt;  type:            string&lt;br&gt;  body:            string&lt;br&gt;  unread_count:    int&lt;br&gt;  timestamp:       ISO8601&lt;br&gt;}" vertex="1">
          <mxGeometry height="152" width="280" x="940" y="506" as="geometry" />
        </mxCell>

