        <mxCell id="e-bw-pw" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;strokeColor=#88bbff;" edge="1" source="cls-bw" target="cls-pw"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-bw-persistw" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;strokeColor=#88bbff;" edge="1" source="cls-bw" target="cls-persistw"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-ns-rp" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=open;strokeColor=#ffcc44;" edge="1" source="cls-ns" target="cls-rp"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ═══════════════════════════════════════════════
             B. DB SCHEMA
        ═══════════════════════════════════════════════ -->
        <mxCell id="b-hdr" parent="1" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="B. Database Schema (Cassandra + PostgreSQL)" vertex="1">
          <mxGeometry height="24" width="360" x="100" y="88" as="geometry" />
        </mxCell>

        <!-- notifications — Cassandra, dark blue -->
        <mxCell id="tbl-notif" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#001a40;fillColor=#003070;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;notifications  (Cassandra)&lt;/b&gt;&lt;hr style=&apos;border-color:#88bbff;&apos;/&gt;notification_id  UUID         PK (clustering)&lt;br&gt;user_id          UUID         partition key&lt;br&gt;type             TEXT         order_update | alert | promo&lt;br&gt;channel          TEXT         in_app | email | sms | push&lt;br&gt;payload          TEXT         (JSON blob)&lt;br&gt;status           TEXT         pending | sent | failed&lt;br&gt;idempotency_key  TEXT         UNIQUE&lt;br&gt;read_at          TIMESTAMP&lt;br&gt;created_at       TIMESTAMP    clustering DESC" vertex="1">
          <mxGeometry height="200" width="350" x="100" y="118" as="geometry" />
        </mxCell>

        <!-- user_preferences — dark green -->
        <mxCell id="tbl-pref" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#1a4a1a;fillColor=#1e6b1e;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;user_preferences  (PostgreSQL)&lt;/b&gt;&lt;hr style=&apos;border-color:#88ff88;&apos;/&gt;pref_id      UUID      PK  DEFAULT gen_random_uuid()&lt;br&gt;user_id      UUID      FK  REFERENCES users(id)&lt;br&gt;channel      TEXT      CHECK IN (in_app,email,sms,push)&lt;br&gt;enabled      BOOLEAN   DEFAULT true&lt;br&gt;quiet_from   TIME      e.g. 22:00&lt;br&gt;quiet_to     TIME      e.g. 07:00&lt;br&gt;locale       VARCHAR(8) DEFAULT 'en-US'&lt;br&gt;updated_at   TIMESTAMP DEFAULT now()&lt;br&gt;UNIQUE (user_id, channel)" vertex="1">
          <mxGeometry height="200" width="360" x="100" y="338" as="geometry" />
        </mxCell>

        <!-- delivery_logs — dark purple -->
        <mxCell id="tbl-log" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#2e0050;fillColor=#4a007a;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;delivery_logs  (PostgreSQL)&lt;/b&gt;&lt;hr style=&apos;border-color:#cc88ff;&apos;/&gt;log_id           UUID       PK&lt;br&gt;notification_id  UUID       FK&lt;br&gt;channel          TEXT&lt;br&gt;status           TEXT       sent | failed | retrying&lt;br&gt;attempt_count    INT        DEFAULT 0&lt;br&gt;last_attempt_at  TIMESTAMP&lt;br&gt;error_message    TEXT&lt;br&gt;INDEX (notification_id, channel)" vertex="1">
          <mxGeometry height="178" width="330" x="100" y="558" as="geometry" />
        </mxCell>

        <!-- notification_templates — dark amber -->
        <mxCell id="tbl-tmpl" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#5a3e00;fillColor=#8a5c00;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;notification_templates  (PostgreSQL)&lt;/b&gt;&lt;hr style=&apos;border-color:#ffcc44;&apos;/&gt;template_id   UUID     PK&lt;br&gt;type          TEXT     order_update | alert | promo&lt;br&gt;channel       TEXT&lt;br&gt;locale        VARCHAR(8)&lt;br&gt;subject       TEXT&lt;br&gt;body_template TEXT     (Mustache / Handlebars)&lt;br&gt;UNIQUE (type, channel, locale)" vertex="1">
          <mxGeometry height="162" width="325" x="100" y="756" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             C. REDIS KEY DESIGN
        ═══════════════════════════════════════════════ -->
        <mxCell id="c-hdr" parent="1" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="C. Redis Key Design" vertex="1">
          <mxGeometry height="24" width="220" x="530" y="88" as="geometry" />
        </mxCell>

        <mxCell id="redis-keys" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=#6b0000;fillColor=#a30000;fontColor=#ffffff;rounded=0;" value="&lt;b&gt;Pub/Sub Channels&lt;/b&gt;&lt;hr style=&apos;border-color:#ff9999;&apos;/&gt;notif:user:{userId}&lt;br&gt;  Type: Pub/Sub channel&lt;br&gt;  Purpose: Fan-out to connected WS nodes&lt;br&gt;  TTL: none (ephemeral)&lt;br&gt;&lt;br&gt;&lt;b&gt;Unread Counter&lt;/b&gt;&lt;hr style=&apos;border-color:#ff9999;&apos;/&gt;unread:{userId}&lt;br&gt;  Type: String (integer)&lt;br&gt;  Cmd: INCR on delivery,  SET 0 on read-all&lt;br&gt;  TTL: 7 days&lt;br&gt;&lt;br&gt;&lt;b&gt;Recent Notifications (hot path)&lt;/b&gt;&lt;hr style=&apos;border-color:#ff9999;&apos;/&gt;notifs:{userId}&lt;br&gt;  Type: Sorted Set&lt;br&gt;  Score: epoch timestamp (ms)&lt;br&gt;  Member: JSON-serialised Notification&lt;br&gt;  Cmd: ZADD notifs:{id} {ts} {payload}&lt;br&gt;  Read: ZREVRANGE notifs:{id} 0 19  // top 20&lt;br&gt;  TTL: 24 hours&lt;br&gt;&lt;br&gt;&lt;b&gt;Rate Limiter&lt;/b&gt;&lt;hr style=&apos;border-color:#ff9999;&apos;/&gt;rate:{userId}:{channel}&lt;br&gt;  Type: String (integer)&lt;br&gt;  Cmd: INCR + EXPIRE 60s&lt;br&gt;  Threshold: 10 per minute per channel&lt;br&gt;&lt;br&gt;&lt;b&gt;Idempotency Guard&lt;/b&gt;&lt;hr style=&apos;border-color:#ff9999;&apos;/&gt;idem:{idempotency_key}&lt;br&gt;  Type: String&lt;br&gt;  Cmd: SET NX EX 86400&lt;br&gt;  Purpose: prevent duplicate processing" vertex="1">
          <mxGeometry height="500" width="330" x="530" y="118" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             D. MODELS
        ═══════════════════════════════════════════════ -->
        <mxCell id="d-hdr" parent="1" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="D. Request / Event Models" vertex="1">
          <mxGeometry height="24" width="240" x="940" y="88" as="geometry" />
