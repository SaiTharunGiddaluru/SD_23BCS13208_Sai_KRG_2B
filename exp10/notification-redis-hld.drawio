        <mxCell id="4bg2fdMJ3XgiNKith0Gf-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Redis Pub/Sub vs Kafka direct: Redis gives sub-ms in-app delivery; Kafka adds durability. Both used together — not either/or." vertex="1">
          <mxGeometry height="30" width="680" x="-575" y="1540" as="geometry" />
        </mxCell>
        <mxCell id="4bg2fdMJ3XgiNKith0Gf-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Cassandra vs PostgreSQL: Cassandra scales writes horizontally (partition key = user_id). PostgreSQL preferred for &lt; 10M users (simpler ops)." vertex="1">
          <mxGeometry height="30" width="700" x="-580" y="1570" as="geometry" />
        </mxCell>
        <mxCell id="4bg2fdMJ3XgiNKith0Gf-3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="SSE vs WebSockets: SSE is unidirectional, simpler, HTTP/2 multiplexed. Use SSE if client never sends on the same channel; WS if bidirectional (ack, chat)." vertex="1">
          <mxGeometry height="30" width="720" x="-575" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="4bg2fdMJ3XgiNKith0Gf-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Redis Sorted Set vs Cassandra for history: Redis for hot recent 20; Cassandra for full history. Two-tier read path keeps P99 &lt; 10ms for the common case." vertex="1">
