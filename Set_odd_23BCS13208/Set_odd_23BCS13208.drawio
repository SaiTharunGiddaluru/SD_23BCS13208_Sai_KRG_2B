        <mxCell id="jh6MWhTRRtHGKybF5RBJ-2" parent="1" style="whiteSpace=wrap;html=1;" value="design an ecommerce&amp;nbsp; system with following requirements&amp;nbsp;" vertex="1">
          <mxGeometry height="60" width="520" x="130" y="120" as="geometry" />
        </mxCell>
        <mxCell id="jh6MWhTRRtHGKybF5RBJ-5" parent="1" style="whiteSpace=wrap;html=1;" value="user login service&lt;div&gt;search service&lt;/div&gt;&lt;div&gt;product catalog service&lt;/div&gt;&lt;div&gt;cart service&amp;nbsp;&lt;/div&gt;&lt;div&gt;oder status service&amp;nbsp;&lt;/div&gt;&lt;div&gt;check out service&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="460" x="130" y="180" as="geometry" />
        </mxCell>
        <mxCell id="jh6MWhTRRtHGKybF5RBJ-7" parent="1" style="whiteSpace=wrap;html=1;" value="optimise the product searching and catalog management in real tima" vertex="1">
          <mxGeometry height="60" width="460" x="130" y="280" as="geometry" />
        </mxCell>
        <mxCell id="jh6MWhTRRtHGKybF5RBJ-12" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Non functional Requirements&lt;/h1&gt;&lt;p&gt;1. latency &amp;lt; 500ms&lt;/p&gt;&lt;p&gt;2. Avalability&amp;gt;&amp;gt;Consistnecy&lt;/p&gt;&lt;p&gt;because at any time user should be able to order products.&lt;/p&gt;&lt;p&gt;3.it has to handle 50m DAU&lt;/p&gt;&lt;p&gt;4. it should be able to handle multiple checkouts&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="270" width="420" x="110" y="610" as="geometry" />
        </mxCell>
        <mxCell id="jh6MWhTRRtHGKybF5RBJ-13" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Functional Requirements&lt;/h1&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;1.user should be able to signup and login and view products&lt;/div&gt;&lt;div&gt;2.user should be able to search differnt product&lt;/div&gt;&lt;/div&gt;&lt;div&gt;3.user should be add items to cart&amp;nbsp;&lt;/div&gt;&lt;div&gt;4.user should be able to order and check order status&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br style=&quot;text-align: center;&quot;&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="350" x="110" y="400" as="geometry" />
        </mxCell>
        <mxCell id="jh6MWhTRRtHGKybF5RBJ-14" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Apis&lt;/span&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;/api/home : should be able to fetch different types of products in the home page&lt;/span&gt;&lt;/h1&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;/api/viewcart :&amp;nbsp; from the cart database deliver the cart products to the user&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;/api/signup :&amp;nbsp; take the user credentials like username and password and hash the password and store it in the user database&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;/api/login :&amp;nbsp; after fetching the user details generate jwt and store in the headers&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;/api/search :&amp;nbsp; should fetch the products from the products database and show it to the user&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;/api/cardid/payment:&amp;nbsp; for this cart user should be able to do the payment&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="790" x="90" y="860" as="geometry" />
        </mxCell>
